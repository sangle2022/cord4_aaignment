PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret_at_least_16_chars

# Optional — comma-separated browser origins (required for strict production hardening)
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Behind nginx / Render / Railway — set so rate limiting uses real client IPs
# TRUST_PROXY=true

# Rate limits (requests per 15 minutes per IP)
# RATE_LIMIT_MAX=400
# LOGIN_RATE_LIMIT_MAX=30

# Max JSON body size (default 100kb)
# JSON_BODY_LIMIT=100kb
